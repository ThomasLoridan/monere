# ============================================================
# Monere — environment variables
# Copy to `.env` and fill in. NEVER commit `.env`.
# Every service reads this file from the repo root in dev.
# In production, inject via your orchestrator's secret manager.
# ============================================================

# ── Runtime mode ────────────────────────────────────────────
# local  = no Docker required: SQLite + in-memory cache (dev fallback)
# docker = Postgres + Redis from docker-compose
MONERE_MODE=local
NODE_ENV=development

# ── Ports ───────────────────────────────────────────────────
GATEWAY_PORT=8080
AUTH_PORT=4001
MARKET_PORT=4002
NEWS_PORT=4003
EARNINGS_PORT=4004
SMART_PORT=4005
AI_PORT=4006
WEB_PORT=5173

# Public origin of the frontend (CORS allow-list)
WEB_ORIGIN=http://localhost:5173

# ── Secrets (GENERATE STRONG RANDOM VALUES) ─────────────────
# openssl rand -hex 32
JWT_SECRET=change-me-openssl-rand-hex-32
# openssl rand -hex 32 — authenticates service-to-service calls behind the gateway
INTERNAL_API_KEY=change-me-openssl-rand-hex-32

# Access token lifetime (short) / refresh token lifetime
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

# ── Database ────────────────────────────────────────────────
# docker mode (matches docker-compose.yml):
# DATABASE_URL=postgresql://monere_auth:monere_auth_pw@localhost:5432/monere?schema=identity
# local mode (SQLite fallback, no Docker):
DATABASE_URL=file:./dev.db

# Postgres superuser bootstrap (compose only)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-postgres-password
POSTGRES_DB=monere

# ── Redis (docker mode; local mode uses in-memory cache) ────
REDIS_URL=redis://localhost:6379

# ── Market data — Finnhub (free tier: https://finnhub.io) ───
# US quotes are real-time (websocket); EU quotes are delayed on
# the free tier — the app displays an honest "delayed" badge.
FINNHUB_API_KEY=

# Chart candles provider: "finnhub" (paid plan) or "yahoo"
# (no key required; unofficial but real market data, used as
# the free fallback for intraday/history candles US + EU).
CHART_PROVIDER=yahoo

# ── LLM — Anthropic (https://console.anthropic.com) ─────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ── Email — Resend (https://resend.com, free tier 100/day) ──
RESEND_API_KEY=
# Must be a verified sender/domain in Resend. On the free tier
# without a domain, use onboarding@resend.dev (test mode).
MAIL_FROM=Monere <onboarding@resend.dev>

# ── SEC EDGAR (free, official) ──────────────────────────────
# SEC requires a descriptive User-Agent with contact email.
SEC_EDGAR_USER_AGENT=Monere/0.1 (contact: you@example.com)

# ── Admin bootstrap ─────────────────────────────────────────
# The seed script creates this admin account. The password is
# printed ONCE by `npm run db:seed` — change it after first login.
ADMIN_EMAIL=admin@monere.local

# ── File storage (S3-compatible; MinIO in compose) ──────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=monere-minio
S3_SECRET_KEY=change-me-minio-secret
S3_BUCKET=monere-uploads

# ── Rate limiting ───────────────────────────────────────────
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW=1 minute
AUTH_RATE_LIMIT_MAX=10
