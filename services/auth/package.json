{
  "name": "@monere/auth",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "gen:schema": "node scripts/gen-schema.mjs",
    "db:generate": "npm run gen:schema && prisma generate",
    "db:push": "prisma db push --skip-generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:migrate": "npm run gen:schema && prisma migrate dev",
    "db:prepare": "npm run db:generate && prisma db push --skip-generate && npm run db:seed"
  },
  "dependencies": {
    "@monere/shared": "*",
    "@prisma/client": "^6.5.0",
    "argon2": "^0.41.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "prisma": "^6.5.0",
    "vitest": "^3.0.8"
  }
}
