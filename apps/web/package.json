  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.2.3",
    "vite-plugin-pwa": "^0.21.2"
  }
